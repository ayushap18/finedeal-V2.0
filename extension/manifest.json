{
  "manifest_version": 3,
  "name": "FineDeal - Smart Price Comparison",
  "version": "4.0.0",
  "description": "AI-powered price comparison and deal tracking across Indian e-commerce sites.",
  "permissions": ["activeTab", "storage", "notifications"],
  "host_permissions": [
    "https://*.amazon.in/*",
    "https://*.flipkart.com/*",
    "https://*.croma.com/*",
    "https://*.myntra.com/*",
    "https://*.snapdeal.com/*",
    "https://*.tatacliq.com/*",
    "https://*.ajio.com/*",
    "https://*.nykaa.com/*",
    "https://*.vijaysales.com/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "FineDeal - Smart Price Comparison",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.amazon.in/*",
        "https://*.flipkart.com/*",
        "https://*.croma.com/*",
        "https://*.myntra.com/*",
        "https://*.snapdeal.com/*",
        "https://*.tatacliq.com/*",
        "https://*.ajio.com/*",
        "https://*.nykaa.com/*",
        "https://*.vijaysales.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
